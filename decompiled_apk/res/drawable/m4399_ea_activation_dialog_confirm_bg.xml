<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="false">
        <shape>
            <corners android:topRightRadius="4.0dip" android:bottomRightRadius="4.0dip" />
            <solid android:color="@color/m4399_color_primary" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <corners android:bottomRightRadius="4.0dip" />
            <solid android:color="@color/m4399_color_primary_dark" />
        </shape>
    </item>
</selector>