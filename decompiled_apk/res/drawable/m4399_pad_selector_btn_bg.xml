            <solid android:color="@color/m4399_pad_color_red_ff5746" />
            <corners android:radius="1.5dip" />
            <size android:height="10.0dip" android:width="20.0dip" />
        </shape>
    </item>
    <item android:state_hovered="true">
        <shape>
            <solid android:color="@color/m4399_pad_color_red_ff5746" />
