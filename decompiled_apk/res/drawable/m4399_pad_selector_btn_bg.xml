    </item>
    <item>
        <shape>
            <stroke android:width="1.0dip" android:color="@color/m4399_pad_color_red_ff5746" android:dashWidth="2.0dip" />
            <corners android:radius="1.5dip" />
            <size android:height="10.0dip" android:width="20.0dip" />
        </shape>
    </item>
