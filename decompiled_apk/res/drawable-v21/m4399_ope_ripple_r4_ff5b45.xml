<?xml version="1.0" encoding="utf-8"?>
<ripple android:shape="rectangle" android:color="@android:color/white"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <selector>
            <item android:state_enabled="false">
                <shape>
                    <solid android:color="@color/m4399_ope_pay_orange_14ffa92d" />
                    <corners android:radius="4.0dip" />
                </shape>
            </item>
            <item android:state_pressed="false">
                <shape>
                    <solid android:color="@color/m4399_ope_pay_red_0dff5b45" />
                    <corners android:radius="4.0dip" />
                </shape>
            </item>
            <item android:state_pressed="true">
                <shape>
                    <solid android:color="#1dff5b45" />
                    <corners android:radius="4.0dip" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>