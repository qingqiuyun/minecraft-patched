<?xml version="1.0" encoding="utf-8"?>
<ripple android:color="@color/m4399_color_ripple_grey"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <selector>
            <item android:state_pressed="true">
                <shape>
                    <solid android:color="@color/m4399_color_primary_dark" />
                    <corners android:radius="25.0dip" />
                </shape>
            </item>
            <item android:state_enabled="false">
                <shape>
                    <solid android:color="#9957be6a" />
                    <corners android:radius="25.0dip" />
                </shape>
            </item>
            <item>
                <shape>
                    <solid android:color="@color/m4399_color_primary" />
                    <corners android:radius="25.0dip" />
                </shape>
            </item>
        </selector>
    </item>
</ripple>