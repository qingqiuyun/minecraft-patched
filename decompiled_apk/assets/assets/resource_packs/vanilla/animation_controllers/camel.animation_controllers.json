{"animation_controllers":{"controller.animation.camel.idle":{"initial_state":"idling","states":{"idling":{"animations":["idle"]}}},"controller.animation.camel.general":{"initial_state":"default","states":{"idling":{"transitions":[{"moving":"variable.moving"},{"sit_down":"query.is_sitting"},{"dashing":"query.has_dash_cooldown && !query.is_on_ground && !query.is_in_water && !query.is_in_lava && !query.is_riding"}],"blend_transition":0.5},"stand_up":{"transitions":[{"sit_down":"query.is_sitting"},{"idling":"query.all_animations_finished"},{"moving":"variable.moving"}],"blend_transition":0.5,"animations":["stand_up"]},"default":{"transitions":[{"idling":"!query.is_sitting"},{"sitting":"query.is_sitting"}],"blend_transition":0.0},"sit_down":{"transitions":[{"stand_up":"!query.is_sitting"}],"blend_transition":0.5,"animations":["sit_down"]},"dashing":{"transitions":[{"idling":"(query.is_on_ground || query.is_in_water || query.is_in_lava || query.is_riding) && !variable.moving"},{"moving":"(query.is_on_ground || query.is_in_water || query.is_in_lava || query.is_riding) && variable.moving"}],"blend_transition":0.5,"animations":["dashing","dashing_sound"]},"sitting":{"transitions":[{"stand_up":"!query.is_sitting"}],"blend_transition":0.5,"animations":["sitting"]},"moving":{"transitions":[{"idling":"!variable.moving"},{"sit_down":"query.is_sitting"},{"dashing":"query.has_dash_cooldown && !query.is_on_ground && !query.is_in_water && !query.is_in_lava && !query.is_riding"}],"blend_transition":0.2,"animations":[{"moving":"math.min(1.0, math.lerp(0.4, 1.25, query.modified_move_speed))"}]}}}},"format_version":"1.10.0"}