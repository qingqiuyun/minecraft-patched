{"minecraft:client_entity":{"description":{"materials":{"default":"wither_boss","armor":"wither_boss_armor"},"spawn_egg":{"overlay_color":"#4d72a0","base_color":"#141414"},"scripts":{"scalex":"variable.scale_xz * variable.base_scale","pre_animation":["variable.base_scale = 2;","variable.swell_clamped = Math.clamp(query.swell_amount, 0.0, 1.0);","variable.wobble = 1.0 + Math.sin(query.swell_amount * 5730) * query.swell_amount * 0.01;","variable.swell_adjustment = Math.pow(variable.swell_clamped, 4);","variable.scale_xz = (1.0 + variable.swell_adjustment * 0.4) * variable.wobble;","variable.scale_y = (1.0 + variable.swell_adjustment * 0.1) / variable.wobble;","variable.body_base_rotation = Math.cos(query.life_time * 114.6);","variable.upper_body_rotation = (0.065 + 0.05 * variable.body_base_rotation) * 180 + query.target_x_rotation;","variable.is_invulnerable = query.invulnerable_ticks > 0.0;","variable.display_normal_skin = (query.invulnerable_ticks <= 0) || ((query.invulnerable_ticks <= 80) && (Math.mod(query.invulnerable_ticks / 5, 2) == 1));"],"scalez":"variable.scale_xz * variable.base_scale","scaley":"variable.scale_y * variable.base_scale"},"render_controllers":["controller.render.wither_boss","controller.render.wither_boss_armor_white","controller.render.wither_boss_armor_blue"],"min_engine_version":"1.8.0","animations":{"scale":"animation.wither_boss.scale","move":"animation.wither_boss.move","look_at_target":"animation.wither_boss.look_at_target"},"animation_controllers":[{"move":"controller.animation.wither_boss.move"}],"identifier":"minecraft:wither","textures":{"armor_blue":"textures/entity/wither_boss/wither_armor_blue","armor_white":"textures/entity/wither_boss/wither_armor_white","invulnerable":"textures/entity/wither_boss/wither_invulnerable","default":"textures/entity/wither_boss/wither"},"geometry":{"default":"geometry.witherBoss","armor":"geometry.witherBoss.armor.v1.8"}}},"format_version":"1.8.0"}