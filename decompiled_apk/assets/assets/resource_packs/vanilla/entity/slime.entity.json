{"minecraft:client_entity":{"description":{"materials":{"outer":"slime_outer","default":"slime"},"spawn_egg":{"texture_index":10,"texture":"spawn_egg"},"identifier":"minecraft:slime","textures":{"default":"textures/entity/slime/slime"},"scripts":{"pre_animation":["variable.squish_factor = (query.previous_squish_value + (query.current_squish_value - query.previous_squish_value) * query.frame_alpha);","variable.bounce = 1 / ((variable.squish_factor / (query.variant * 0.5 + 1)) + 1);","variable.horizontal_scale_amount = variable.bounce * query.variant;","variable.vertical_scale_amount = (1 / variable.bounce) * query.variant;"],"scaleX":"variable.horizontal_scale_amount","scaleZ":"variable.horizontal_scale_amount","scaleY":"variable.vertical_scale_amount"},"render_controllers":["controller.render.slime","controller.render.slime_armor"],"geometry":{"default":"geometry.slime","armor":"geometry.slime.armor"}}},"format_version":"1.8.0"}