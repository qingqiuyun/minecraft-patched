					"v.display2_13 = math.floor(v.test_variable33/math.pow(10, 2)) - math.floor(v.test_variable33/math.pow(10, 2+1))*10 + 48;",
					"v.display2_14 = math.floor(v.test_variable33/math.pow(10, 1)) - math.floor(v.test_variable33/math.pow(10, 1+1))*10 + 48;",
					"v.display2_15 = math.floor(v.test_variable33/math.pow(10, 0)) - math.floor(v.test_variable33/math.pow(10, 0+1))*10 + 48;",

