					"v.display1_8  = 121;",
					"v.display1_9  = math.floor(v.test_variable22/math.pow(10, 6)) - math.floor(v.test_variable22/math.pow(10, 6+1))*10 + 48;",
					"v.display1_10 = math.floor(v.test_variable22/math.pow(10, 5)) - math.floor(v.test_variable22/math.pow(10, 5+1))*10 + 48;",
					"v.display1_11 = math.floor(v.test_variable22/math.pow(10, 4)) - math.floor(v.test_variable22/math.pow(10, 4+1))*10 + 48;",
					"v.display1_12 = math.floor(v.test_variable22/math.pow(10, 3)) - math.floor(v.test_variable22/math.pow(10, 3+1))*10 + 48;",
					"v.display1_13 = math.floor(v.test_variable22/math.pow(10, 2)) - math.floor(v.test_variable22/math.pow(10, 2+1))*10 + 48;",
					"v.display1_14 = math.floor(v.test_variable22/math.pow(10, 1)) - math.floor(v.test_variable22/math.pow(10, 1+1))*10 + 48;",
					"v.display1_15 = math.floor(v.test_variable22/math.pow(10, 0)) - math.floor(v.test_variable22/math.pow(10, 0+1))*10 + 48;",
					
					"v.display2_0  = (v.infor_request3 >= 0) ? 32:45;",
					"v.display2_1  = math.floor(v.test_variable3/math.pow(10, 6)) - math.floor(v.test_variable3/math.pow(10, 6+1))*10 + 48;",
					"v.display2_2  = math.floor(v.test_variable3/math.pow(10, 5)) - math.floor(v.test_variable3/math.pow(10, 5+1))*10 + 48;",
					"v.display2_3  = math.floor(v.test_variable3/math.pow(10, 4)) - math.floor(v.test_variable3/math.pow(10, 4+1))*10 + 48;",
