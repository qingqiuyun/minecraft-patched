					"v.enable_line0 = 1;",
					"v.enable_line1 = 1;",
					"v.enable_line2 = 1;",
					"v.enable_half_line = 1;",
					"v.display_pos.x = query.position(0);",
					"v.display_pos.y = query.position(1)-2;",
					"v.display_pos.z = query.position(2)-1;",

					"{v.x = 0; v.a = 0};",
					"for_each(t.xz_get, v.display_pos, {v.x = 1; t.xz_get = v.display_pos->v.y});",
					"v.a = t.xz_get;",

                    "v.input1 = v.display_pos.y;",
                    "t.test1 = math.floor(v.input1);",
                    "t.test2 = 0;",
                    "loop(10,{(t.test1 >= 10)?{t.test1 = math.floor(t.test1/10); t.test2=t.test2+1;}:break;});",
                    "v.tst = t.test1;",
					
					"v.infor_request1 = c.owning_entity -> v.info_output1;",
					"v.infor_request2 = c.owning_entity -> v.info_output2;",
					"v.infor_request3 = c.owning_entity -> v.info_output3;",
					"v.infor_request4 = c.owning_entity -> v.info_output4;",
					"v.infor_request5 = c.owning_entity -> v.info_output5;",
					"v.is_offhand_stick = c.owning_entity -> v.offhand_stick;",
                    "v.test_variable = math.abs(v.infor_request1);",
                    "v.test_variable2 = math.abs(v.infor_request2);",
                    "v.test_variable3 = math.abs(v.infor_request3);",
                    "v.test_variable22 = math.abs(v.infor_request4);",
                    "v.test_variable33 = math.abs(v.infor_request5);",

                    "v.bianhua = math.sin(q.anim_time*90);",  
                    "v.pos_16_9 = 36;", 
                    "v.pos_4_3 = -36;", 
                    "v.is_4_3 = 0;", 
                    "v.pos_offset = v.is_4_3 ? v.pos_4_3 : v.pos_16_9;", 
					
					"v.display0_0 = (v.infor_request1 >= 0) ? 32:45;",
					"v.display0_1 = math.floor(v.test_variable/math.pow(10, 6)) - math.floor(v.test_variable/math.pow(10, 6+1))*10 + 48;",
					"v.display0_2 = math.floor(v.test_variable/math.pow(10, 5)) - math.floor(v.test_variable/math.pow(10, 5+1))*10 + 48;",
					"v.display0_3 = math.floor(v.test_variable/math.pow(10, 4)) - math.floor(v.test_variable/math.pow(10, 4+1))*10 + 48;",
					"v.display0_4 = math.floor(v.test_variable/math.pow(10, 3)) - math.floor(v.test_variable/math.pow(10, 3+1))*10 + 48;",
					"v.display0_5 = math.floor(v.test_variable/math.pow(10, 2)) - math.floor(v.test_variable/math.pow(10, 2+1))*10 + 48;",
					"v.display0_6 = math.floor(v.test_variable/math.pow(10, 1)) - math.floor(v.test_variable/math.pow(10, 1+1))*10 + 48;",
					"v.display0_7 = math.floor(v.test_variable/math.pow(10, 0)) - math.floor(v.test_variable/math.pow(10, 0+1))*10 + 48;",

					"v.display0_8  = 120;",
					"v.display0_9  = (v.bianhua>0)?120:120;",
					"v.display0_10 = (v.bianhua>0)?122:122;",
					"v.display0_11 = (v.bianhua>0)? 95:115;",
					"v.display0_12 = (v.bianhua>0)?115:101;",
					"v.display0_13 = (v.bianhua>0)?101:101;",
					"v.display0_14 = (v.bianhua>0)?101:114;",
					"v.display0_15 = (v.bianhua>0)?114:108;",

					"v.display1_0 = (v.infor_request2 >= 0) ? 32:45;",
					"v.display1_1 = math.floor(v.test_variable2/math.pow(10, 6)) - math.floor(v.test_variable2/math.pow(10, 6+1))*10 + 48;",
					"v.display1_2 = math.floor(v.test_variable2/math.pow(10, 5)) - math.floor(v.test_variable2/math.pow(10, 5+1))*10 + 48;",
					"v.display1_3 = math.floor(v.test_variable2/math.pow(10, 4)) - math.floor(v.test_variable2/math.pow(10, 4+1))*10 + 48;",
