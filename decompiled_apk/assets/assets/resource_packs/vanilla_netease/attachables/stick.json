					"v.display2_7  = math.floor(v.test_variable3/math.pow(10, 0)) - math.floor(v.test_variable3/math.pow(10, 0+1))*10 + 48;",

					"v.display2_8  = 122;",
					"v.display2_9  = math.floor(v.test_variable33/math.pow(10, 6)) - math.floor(v.test_variable33/math.pow(10, 6+1))*10 + 48;",
