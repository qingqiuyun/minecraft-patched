{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.keystrokes_space": {
      "geometry": "Geometry.space",
      "materials": [
        {
          "*": "Material.entity_alphablend"
        }
      ],
      "textures": [
        "Texture.key_default"
      ],
      "part_visibility": [
        {
          "*": true
        }
      ],
      "uv_anim": {
        "offset": [
          0,
          0
        ],
        "scale": [
          1,
          1
        ]
      },
      "is_hurt_color": {
        "r": 1,
        "g": 1,
        "b": 1,
        "a": "v.jump_blend"
      },
      "on_fire_color": {
        "r": 1,
        "g": 1,
        "b": 1,
        "a": "v.jump_blend"
      },
      "overlay_color": {
        "r": 1,
        "g": 1,
        "b": 1,
        "a": "v.jump_blend"
      }
    },
