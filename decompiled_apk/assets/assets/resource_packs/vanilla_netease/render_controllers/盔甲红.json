    },
    "controller.render.armor.helmet": {
      "geometry": "geometry.default_custom",
      "materials": [
        {
          "*": "variable.is_enchanted ? material.enchanted : material.default"
        }
      ],
      "textures": [
        "texture.default",
        "texture.enchanted"
      ],
      "part_visibility": [
        {
          "*": false
        },
