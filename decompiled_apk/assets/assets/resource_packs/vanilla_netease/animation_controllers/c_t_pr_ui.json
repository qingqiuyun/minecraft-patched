  "controller.animation.t_pr_jump_dynamic": {
   "states": {
    "default": {
     "blend_transition": 0.01,
     "transitions": [
      {"1": "q.is_jumping && variable.jump != 1.0"},
      {"2": "q.is_jumping && variable.jump == 1.0"}
     ]
    },
    "1": {
     "animations": [
      "a_t_pr_jump_dynamic"
     ],
     "blend_transition": 0.01,
     "transitions": [
      {"default": "!q.is_jumping && variable.jump != 1.0"}
     ]
    },
    "2": {
     "animations": [
      "a_t_pr_jump_dynamic",
      "a_t_pr_empty"
     ],
     "blend_transition": 0.01,
     "transitions": [
      {"default": "(!q.is_jumping || query.any_animation_finished) && variable.jump == 1.0"}
     ]
    }
   }
  },
  "controller.animation.t_pr_lmb_dynamic": {
   "states": {
    "default": {
     "blend_transition": 0.02,
     "transitions": [
