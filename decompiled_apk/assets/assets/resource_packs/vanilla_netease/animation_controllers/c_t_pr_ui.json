  },
  "controller.animation.t_pr_ui": {
   "states": {
    "default": {
     "blend_transition": 0,
     "transitions": [
      {"1": "1.0"}
     ]
    },
    "1": {
     "animations": [
      "a_t_pr_ui",
      "a_t_pr_ui_rotation"
     ],
     "blend_transition": 0,
     "transitions": [
      {"default": "0.0"}
     ]
