   }
  },
  "controller.animation.t_pr_jump_blend": {
   "states": {
    "default": {
     "blend_transition": 0.0,
     "transitions": [
      {"1": "1.0"}
     ],
     "on_entry": [
      "v.jump_blend = (q.is_jumping == 1.0 ? Math.min((v.jump_blend + v.jump_blend_time_enter), 1) : Math.max((v.jump_blend - v.jump_blend_time_appear), 0));"
     ]
    },
    "1": {
     "animations": [
      "a_t_pr_empty"
     ],
     "blend_transition": 0.0,
     "transitions": [
      {"default": "1.0"}
     ],
     "on_entry": [
      "v.jump_blend = (q.is_jumping == 1.0 ? Math.min((v.jump_blend + v.jump_blend_time_enter), 1) : Math.max((v.jump_blend - v.jump_blend_time_appear), 0));"
     ]
    }
   }
  },
  "controller.animation.t_pr_lmb_blend": {
   "states": {
    "default": {
     "blend_transition": 0.0,
     "transitions": [
      {"1": "1.0"}
     ],
     "on_entry": [
      "v.lmb_blend = (variable.attack_time && !v.rmb_block_all ? Math.min((v.lmb_blend + v.lmb_blend_time_enter), 1) : Math.max((v.lmb_blend - v.lmb_blend_time_appear), 0));",
      "v.lmb_blend_mix = (variable.attack_time && !v.rmb_block_all ? Math.min((v.lmb_blend_mix + v.lmb_mix_blend_time_enter), variable.attack_time * 1) : Math.max((v.lmb_blend_mix - v.lmb_mix_blend_time_appear), 0));"
     ]
    },
    "1": {
     "animations": [
      "a_t_pr_empty"
     ],
     "blend_transition": 0.0,
     "transitions": [
      {"default": "1.0"}
     ],
     "on_entry": [
      "v.lmb_blend = (variable.attack_time && !v.rmb_block_all ? Math.min((v.lmb_blend + v.lmb_blend_time_enter), 1) : Math.max((v.lmb_blend - v.lmb_blend_time_appear), 0));",
      "v.lmb_blend_mix = (variable.attack_time && !v.rmb_block_all ? Math.min((v.lmb_blend_mix + v.lmb_mix_blend_time_enter), variable.attack_time * 1) : Math.max((v.lmb_blend_mix - v.lmb_mix_blend_time_appear), 0));"
     ]
    }
   }
  },
  "controller.animation.t_pr_rmb_blend": {
   "states": {
    "default": {
     "blend_transition": 0.0,
     "transitions": [
      {"1": "1.0"}
     ],
     "on_entry": [
      "v.rmb_blend = ((query.is_using_item && query.get_equipped_item_name(0, 1) != 'fishing_rod') || (v.rmb_block_all && variable.attack_time) ? Math.min((v.rmb_blend + v.rmb_blend_time_enter), 1) : Math.max((v.rmb_blend - v.rmb_blend_time_appear), 0));",
      "v.rmb_blend_mix_block = ((query.is_using_item && query.get_equipped_item_name(0, 1) != 'fishing_rod') || (v.rmb_block_all && variable.attack_time) ? Math.min((v.rmb_blend_mix_block + v.lmb_mix_blend_time_enter), query.is_using_item ? 1 : variable.attack_time * 1) : Math.max((v.rmb_blend_mix_block - v.lmb_mix_blend_time_appear), 0));"
     ]
    },
    "1": {
     "animations": [
