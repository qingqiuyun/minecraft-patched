{
 "format_version": "1.10.0",
 "animation_controllers": {
  "controller.animation.t_pr_root": {
   "states": {
    "default": {
     "blend_transition": 0,
     "transitions": [
      {"1": "1.0"}
     ]
    },
    "1": {
     "animations": [
      "c_t_pr_ui",
      "c_t_pr_jump_blend",
      "c_t_pr_lmb_blend",
      "c_t_pr_rmb_blend",
