{//“物理”投掷物动画，魔改自潜影贝
	"format_version" : "1.8.0",
	"animations" : {
		"animation.actor.billboard" : {
			"loop" : true,
      "bones": {
				"body" : {
					"rotation" : [ "math.cos(query.life_time * 120) * 180", "math.sin(query.life_time * 120) * 180", "math.sin(query.life_time * 170) * 360" ]
				}
      }
		}
	}
}
