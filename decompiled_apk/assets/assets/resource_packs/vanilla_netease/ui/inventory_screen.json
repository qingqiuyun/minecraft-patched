    "$edit_box_background": "$16x",
    "$is_search_box": true
  },
  
  "cell_image": {
    "alpha": 0.12,
    "color": "$primary"
  },
  "cell_image_recipe_default@crafting.cell_image": {
    "texture": "$fk",
    "$cell_image_size|default": [
      "default",
      "default"
    ],
    "size": "$cell_image_size",
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "$background_image_control_name",
        "resolve_sibling_scope": true,
        "source_property_name": "(#container_item_background = 0)",
        "target_property_name": "#visible"
      }
    ]
  },
  "cell_image_recipe_group_head_collapsed@crafting.cell_image": {
    "texture": "$fk",
    "$cell_image_size|default": [
      "default",
      "default"
    ],
    "size": "$cell_image_size",
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "$background_image_control_name",
        "resolve_sibling_scope": true,
        "source_property_name": "(#container_item_background = 1)",
        "target_property_name": "#visible"
      }
    ]
  },
  "cell_image_recipe_group_head_expanded@crafting.cell_image": {
    "texture": "$fk",
    "alpha": 1,
    "color": "$primary",
    "$cell_image_size|default": [
      "default",
      "default"
    ],
    "size": "$cell_image_size",
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "$background_image_control_name",
        "resolve_sibling_scope": true,
        "source_property_name": "(#container_item_background = 2)",
        "target_property_name": "#visible"
      }
    ]
  },
  "cell_image_recipe_group_item@crafting.cell_image": {
    "texture": "$fk",
    "$cell_image_size|default": [
      "default",
      "default"
    ],
    "size": "$cell_image_size",
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "$background_image_control_name",
        "resolve_sibling_scope": true,
        "source_property_name": "(#container_item_background = 3)",
        "target_property_name": "#visible"
      }
    ]
  },
  "cell_image_recipe_selected@crafting.cell_image": {
    "texture": "$fk",
    "alpha": 1,
    "color": "$primary",
    "$cell_image_size|default": [
      "default",
      "default"
    ],
    "size": "$cell_image_size",
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "$background_image_control_name",
        "resolve_sibling_scope": true,
        "source_property_name": "(#container_item_background = 4)",
        "target_property_name": "#visible"
      }
    ]
  },
  "cell_image_recipe_default_red@crafting.cell_image": {
    "texture": "$fk",
    "$cell_image_size|default": [
      "default",
      "default"
    ],
    "size": "$cell_image_size",
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "$background_image_control_name",
        "resolve_sibling_scope": true,
        "source_property_name": "(#container_item_background = 5)",
        "target_property_name": "#visible"
      }
    ]
  },
  "recipe_container_cell_images": {
    "type": "panel",
    "$cell_images_binding_condition|default": "visible",
    "controls": [
      {
        "cell_image_recipe_default@crafting.cell_image_recipe_default": {}
      },
      {
        "cell_image_recipe_group_head_collapsed@crafting.cell_image_recipe_group_head_collapsed": {}
      },
      {
        "cell_image_recipe_group_head_expanded@crafting.cell_image_recipe_group_head_expanded": {}
      },
      {
        "cell_image_recipe_group_item@crafting.cell_image_recipe_group_item": {}
      },
      {
        "cell_image_recipe_selected@crafting.cell_image_recipe_selected": {}
      },
      {
        "cell_image_recipe_default_red@crafting.cell_image_recipe_default_red": {}
      }
    ],
    "bindings": [
      {
        "binding_name": "#container_item_background",
        "binding_type": "collection",
        "binding_collection_name": "$item_collection_name",
        "binding_condition": "$cell_images_binding_condition"
      }
    ]
  },
  
  "recipe_book_uncheck@common.root_panel": {
    "layer": 1,
    "size": [
      140,
      "100%-25px"
    ],
    "anchor_from": "bottom_left",
    "anchor_to": "bottom_left",
    "anims": [
      "@crafting.recipe_uncheck_anim"
    ],
    "controls": [
      {
        "gamepad_helper_bumpers@crafting.gamepad_helper_bumpers": {
          "size": [
            146,
            16
          ],
          "offset": [
            0,
            -5
          ],
          "anchor_from": "top_left",
          "anchor_to": "bottom_left"
        }
      },
      {
        "tab_navigation_panel@crafting.tab_panel": {
          "layer": 50000,
          "size": [
            20,
            "100%-10px"
          ],
          "anchor_from": "bottom_right",
          "anchor_to": "bottom_right",
          "offset": [
            25,
            -5
          ]
        }
      },
      {
        "bg@common.common_panel": {
          "layer": 8,
          "$show_close_button": false
        }
      },
      {
        "tab_content_panel@crafting.tab_content": {
          "size": [
            "100%",
            "100%"
          ],
          "anchor_from": "right_middle",
          "anchor_to": "right_middle",
          "layer": 8,
          "$scrolling_pane_control": "crafting.recipe_book_scroll_panel"
        }
      }
    ]
  },
  "recipe_book_check@crafting.recipe_book_uncheck": {
    "anims": [
      "@crafting.recipe_check_anim"
    ],
    "$scrolling_pane_control": "common.empty_panel"
  },
  
  "recipe": {
    "type": "panel",
    "size": [
      "100%",
      "100%"
    ],
    "controls": [
      {
        "check": {
          "type": "collection_panel",
          "factory": {
            "name": "check",
            "control_name": "crafting.recipe_book_check",
            "max_children_size": 1
          },
          "bindings": [
            {
              "binding_type": "view",
              "source_control_name": "crafting.recipe_toggle",
              "source_property_name": "#toggle_state",
              "target_property_name": "#length"
            },
            {
              "binding_type": "view",
              "source_property_name": "(1 * #length)",
              "target_property_name": "#collection_length"
            }
          ]
        }
      },
      {
        "uncheck": {
          "type": "collection_panel",
          "factory": {
            "name": "uncheck",
            "control_name": "crafting.recipe_book_uncheck",
            "max_children_size": 1
          },
          "bindings": [
            {
              "binding_type": "view",
              "source_control_name": "crafting.recipe_toggle",
              "source_property_name": "#toggle_state",
              "target_property_name": "#length"
            },
            {
              "binding_type": "view",
              "source_property_name": "(1 * (not #length))",
              "target_property_name": "#collection_length"
            }
          ]
        }
      }
    ]
  },
  
  "recipe_toggle@Quasar_toggle.toggle": {
    "size": [
      165,
      20
    ],
    "anchor_from": "bottom_right",
    "anchor_to": "bottom_right",
    "$button_icon": "textures/Quasar/container/recipe",
    "$toggle_name": "recipe_toggle",
    "$toggle_view_binding_name": "crafting.recipe_toggle",
    "$toggle_check_anim": "@pause.toggle_check",
    "$toggle_uncheck_anim": "@pause.toggle_uncheck",
    "$custom_controls": "pause.icon_controls",
    "$unchecked_controls": "Quasar_toggle.normal_toggle_uncheck",
    "$checked_controls": "Quasar_toggle.normal_toggle_check"
  },
  
  
  "recipe_uncheck_anim": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "from": [ 0, 0 ],
    "to": [ -165, 0 ]
  },
  "recipe_check_anim": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "to": [ 0, 0 ],
    "from": [ -165, 0 ]
  }
}