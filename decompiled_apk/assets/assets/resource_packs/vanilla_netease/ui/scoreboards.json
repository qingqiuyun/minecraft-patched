{
  "namespace": "scoreboard",
  "scoreboard_sidebar_player": {
    "font_type": "$global_font_type",
    "color": "$onprimarycontainer"
  },
  "scoreboard_sidebar_score": {
    "type": "label",
    "layer": 2,
    "size": [
      "default",
      10
    ],
    "font_type": "$global_font_type",
    "text": "#player_score_sidebar",
    "text_alignment": "right",
    "anchor_from": "top_right",
    "anchor_to": "top_right",
    "inherit_max_sibling_width": true,
    "locked_alpha": 0,
    "visible": false,
    "$alpha|default": 0,
    "alpha": "$alpha",
    "color": "$onprimary",
    "variables": [
      {
        "requires": "$sidebar_score",
        "$alpha": 1
      }
    ],
    "bindings": [
      {
        "binding_name": "#player_score_sidebar",
        "binding_type": "collection",
        "binding_collection_name": "scoreboard_scores"
      }
    ]
  },
  "scoreboard_sidebar": {
    "type": "panel",
    "size": [
      "100%cm",
      "100%cm"
    ],
    "anims": [
      "@scoreboard.scoreboard_offset_anim_pop",
      "@scoreboard.scoreboard_offset_anim_push"
    ],
    "$offset": [
      0,
      0
    ],
    "animation_reset_name": "screen_animation_reset",
    "bindings": [
      {
        "binding_name": "#scoreboard_sidebar_visible",
        "binding_type": "global",
        "binding_name_override": "#visible"
      }
    ],
    "controls": [
      {
        "main_score": {
          "type": "image",
          "alpha": "$global_alpha",
          "color": "$background",
          "texture": "$16x",
          "size": [
            "100%cm",
            "100%c+5px-12px"
          ],
          "controls": [
            {
              "displayed_objective": {
                "type": "label",
                "offset": [
                  0,
                  2
                ],
                "size": [
                  "default",
                  12
                ],
                "font_size": "normal",
                "font_type": "$global_font_type",
                "text": "#objective_sidebar_name",
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "text_alignment": "center",
                "inherit_max_sibling_width": true,
                "locked_alpha": 1,
                "layer": 1,
                "color": "$onsecondarycontainer",
                "controls": [],
                "bindings": [
                  {
                    "binding_name": "#objective_sidebar_name",
                    "binding_type": "global"
                  }
                ]
              }
            },
            {
              "bg": {
                "type": "image",
                "texture": "textures/Quasar/direction/down",
                "alpha": "$global_alpha",
                "color": "$background",
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "size": [
                  "100%sm+4px",
                  12
                ]
              }
            },
            {
              "lists": {
                "type": "panel",
                "anchor_from": "bottom_left",
                "anchor_to": "bottom_left",
                "inherit_max_sibling_width": true,
                "offset": [
                  2,
                  -1
                ],
                "size": [
                  "100%cm",
                  "100%cm"
                ],
                "controls": [
                  {
                    "players": {
                      "type": "stack_panel",
                      "anchor_from": "top_left",
                      "anchor_to": "top_left",
                      "size": [
                        "100%cm",
                        "100%c"
                      ],
                      "orientation": "vertical",
                      "collection_name": "scoreboard_players",
                      "factory": {
                        "name": "player_list_factory",
                        "control_name": "scoreboard.scoreboard_sidebar_player"
                      },
                      "bindings": [
                        {
                          "binding_name": "#scoreboard_sidebar_size",
                          "binding_type": "global",
                          "binding_name_override": "#collection_length"
                        }
                      ]
                    }
                  },
                  {
                    "scores": {
                      "type": "stack_panel",
                      "anchor_from": "top_right",
                      "anchor_to": "top_right",
                      "size": [
                        "100%cm",
                        "100%c"
                      ],
                      "orientation": "vertical",
                      "collection_name": "scoreboard_scores",
                      "factory": {
                        "name": "player_score_factory",
                        "control_name": "scoreboard.scoreboard_sidebar_score"
                      },
                      "bindings": [
                        {
                          "binding_name": "#scoreboard_sidebar_size",
                          "binding_type": "global",
                          "binding_name_override": "#collection_length"
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "bloom": {
          "type": "image",
          "texture": "$bloom",
          "color": "$shadow",
          "alpha": "$global_bloom_alpha",
          "size": [
            "100%sm+20px",
            "100%sm+20px"
          ]
        }
      },
      {
        "icon_0": {
          "type": "image",
          "texture": "textures/Quasar/hud/scoreboard",
          "size": [
            "100%y",
            "25%sm"
          ],
          "alpha": 0.3,
          "layer": 2
        }
      }
    ]
  },
  "scoreboard_offset_anim_pop": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "from": [
      500,
      10
    ],
    "to": "$offset",
    "play_event": "screen.entrance_pop",
    "end_event": "screen.entrance_end"
  },
  "scoreboard_offset_anim_push": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "to": [
      500,
      10
    ],
    "from": "$offset",
    "play_event": "screen.exit_push",
    "end_event": "screen.exit_end"
  }
}