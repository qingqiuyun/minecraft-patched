{
    "namespace": "common",
    "base_screen": {
        "$is_hud": false,
        "$is_container|default": false,
        "modifications": [
            {
                "array_name": "controls",
                "operation": "insert_front",
                "value": [
                    {
                        "debug_info": {
                            "type": "label",
                            "layer": 10000,
                            "ignored": "(not $debug or $screen_content = 'toast_screen.toast_screen_content' or $screen_content = 'hud.hud_content')",
                            "text": "('Screen Content = ' + $screen_content + '\nScreen Background = ' + $screen_bg_content + '\nQuasar UI')",
                            "anchor_from": "top_left",
                            "anchor_to": "top_left",
                            "font_type": "$global_font_type",
                            "offset": [
                                "2%",
                                "2%"
                            ],
                            "visible": "(not ($screen_content = 'debug_screen.content_panel'))"
                        }
                    },
                    {
                        "Doll@Quasar/Doll.Doll": {}
                    },
                    {
                        "Info_debug": {
                            "type": "label",
                            "text": "Quasar UI Preview v2.1\nMady by Elaina Official\n测试发版不代表最终品质",
                            "text_alignment": "right",
                            "ignored": "(not$debug)",
                            "anchor_from": "bottom_right",
                            "anchor_to": "bottom_right",
                            "size": [
                                "default",
                                "default"
                            ],
                            "font_type": "$global_font_type",
                            "font_scale_factor": 0.8,
                            "alpha": 0.15
                        }
                    },
                    {
                        "Info_Release": {
                            "type": "label",
                            "text": "Quasar UI Release v2.1\nMady by Elaina Official",
                            "text_alignment": "right",
                            "ignored": "($debug)",
                            "anchor_from": "bottom_right",
                            "anchor_to": "bottom_right",
                            "size": [
                                "default",
                                "default"
                            ],
                            "font_type": "$global_font_type",
                            "font_scale_factor": 0.8,
                            "alpha": 0.15
                        }
                    },
                    {
                        "bg": {
                            "type": "panel",
                            "size": [
                                "10%",
                                "100%x"
                            ],
                            "ignored": "(not $is_container)",
                            "anchor_from": "bottom_right",
                            "anchor_to": "bottom_right",
                            "controls": [
                                {
                                    "bg": {
                                        "type": "image",
                                        "texture": "textures/Quasar/circle",
                                        "alpha": 0.2,
                                        "color": "$background",
                                        "animation_reset_name": "screen_animation_reset",
                                        "anims": [
                                            "@common.bg_size_entrance_pop",
                                            "@common.bg_size_entrance_push",
                                            "@common.bg_size_exit_pop",
                                            "@common.bg_size_exit_push"
                                        ]
                                    }
                                }
                            ]
                        }
                    }
                ]
            }
        ]
    },
    "inventory_screen_common": {
        "$is_container": true,
        "$screen_animations": [
            "@common.screen_exit_animation_push_fade",
            "@common.screen_exit_animation_pop_fade",
            "@common.screen_entrance_animation_push_fade",
            "@common.screen_entrance_animation_pop_fade"
        ]
    },
    "highlight_slot_panel": {
        "type": "panel",
        "allow_clipping": false,
        "controls": [
            {
                "highlight@common.highlight_slot": {
                    "controls": [
                        {
                            "hover_text": {
                                "layer": 29,
                                "type": "label",
                                "text": "#hover_text",
                                "anchor_from": "top_left",
                                "anchor_to": "top_left",
                                "font_type": "$global_font_type",
                                "color": "$onprimarycontainer",
                                "offset": [
                                    25,
                                    4
                                ],
                                "size": [
                                    "default",
                                    "default"
                                ],
                                "$hover_text_binding_name|default": "#hover_text",
                                "bindings": [
                                    {
                                        "binding_name": "$hover_text_binding_name",
                                        "binding_name_override": "#hover_text",
                                        "binding_type": "collection",
                                        "binding_collection_name": "$item_collection_name"
                                    },
                                    {
                                        "binding_name": "#item_id_aux",
                                        "binding_type": "collection",
                                        "binding_collection_name": "$item_collection_name"
                                    },
                                    {
                                        "binding_type": "view",
                                        "source_property_name": "(not (#item_id_aux = -1))",
                                        "target_property_name": "#visible"
                                    }
                                ],
                                "controls": [
                                    {
                                        "background": {
                                            "type": "image",
                                            "texture": "$16x",
                                            "controls": [
                                                {
                                                    "bloom": {
                                                        "type": "image",
                                                        "texture": "$bloom",
                                                        "alpha": "$global_bloom_alpha",
                                                        "color": "$shadow",
                                                        "layer": -1,
                                                        "size": [
                                                            "100%+20px",
                                                            "100%+20px"
                                                        ]
                                                    }
                                                }
                                            ],
                                            "size": [
                                                "100%+10px",
                                                "100%+8px"
                                            ],
                                            "alpha": 0.6,
                                            "color": "$background",
                                            "layer": -1
                                        }
                                    }
                                ]
                            }
                        }
                    ],
                    "bindings": [
                        {
                            "binding_name": "#show_persistent_bundle_hover_text",
                            "binding_name_override": "#visible"
                        }
                    ]
                }
            },
            {
                "white_border@common.white_border_slot": {
                    "bindings": [
                        {
                            "binding_name": "#show_persistent_bundle_hover_text",
                            "binding_name_override": "#visible"
                        }
                    ]
                }
            }
        ]
    },
    "hover_text_modified": {
        "type": "label",
        "text": "#hover_text",
        "layer": 5,
        "allow_clipping": false,
        "font_type": "$global_font_type",
        "color": "$onprimarycontainer",
        "size": [
            "default",
            "default"
        ],
        "controls": [
            {
                "background": {
                    "type": "image",
                    "texture": "$16x",
                    "controls": [
                        {
                            "bloom": {
                                "type": "image",
                                "texture": "$bloom",
                                "alpha": "$global_bloom_alpha",
                                "color": "$shadow",
                                "layer": -1,
                                "size": [
                                    "100%+20px",
                                    "100%+20px"
                                ]
                            }
                        }
                    ],
                    "size": [
                        "100%+10px",
                        "100%+8px"
                    ],
                    "alpha": 0.6,
                    "color": "$background",
                    "layer": -1
                }
            }
        ]
    },
    "item_panel_image": {
        "type": "image",
        "size": [
            "100%cm - 12px",
            "100%cm - 12px"
        ],
        "layer": 30,
        "visible": "#visible",
        "$target_alpha": 0.6,
        "alpha": "$alpha_anim",
        "texture": "$16x",
        "color": "$background",
        "controls": [
            {
                "item_text_label@common.item_text_label": {}
            },
            {
                "bloom": {
                    "type": "image",
                    "texture": "$bloom",
                    "alpha": "$alpha_anim",
                    "color": "$shadow",
                    "$target_alpha": "$global_bloom_alpha",
                    "layer": -1024,
                    "size": [
                        "100%sm+20px",
                        "100%sm+20px"
                    ]
                }
            }
        ]
    },
    "item_text_label": {
        "type": "label",
        "layer": 1,
        "$target_alpha": 1,
        "alpha": "$alpha_anim",
        "text": "#selected_hover_text",
        "font_type": "$global_font_type",
        "color": "$onprimarycontainer",
        "size": [
            "default",
            "default"
        ],
        "localize": false
    },
    "anim_item_details_alpha": {
        "anim_type": "alpha",
        "easing": "in_quint",
        "destroy_at_end": "selected_item_details",
        "duration": 2,
        "from": "$target_alpha",
        "to": 0
    },
    "stack_count_label": {
        "font_type": "$global_font_type",
        "layer": 45,
        "color": "$onprimarycontainer"
    },
    "inventory_panel": {
        "type": "image",
        "texture": "$16x",
        "color": "$primary",
        "alpha": 0.12,
        "$container_size": [
            "100%c",
            "100%c"
        ],
        "animation_reset_name": "screen_animation_reset",
        "anims": [
            "@common.container_entrance_size_pop",
            "@common.container_entrance_size_push",
            "@common.container_exit_size_pop",
            "@common.container_exit_size_push"
        ],
        "clips_children": true,
        "anchor_from": "bottom_middle",
        "anchor_to": "bottom_middle",
        "offset": [
            0,
            -26
        ],
        "controls": [
            {
                "inventory_grid": {
                    "type": "grid",
                    "size": [
                        162,
                        54
                    ],
                    "anchor_from": "bottom_middle",
                    "anchor_to": "bottom_middle",
                    "grid_dimensions": [
                        9,
                        3
                    ],
                    "grid_item_template": "common.grid_item_for_inventory",
                    "collection_name": "inventory_items"
                }
            }
        ]
    },
    "cell_image": {
        "type": "image",
        "texture": "textures/Quasar/empty",
        "layer": 1
    },
    "hotbar_grid_template_modified": {
        "type": "image",
        "texture": "$16x",
        "color": "$primary",
        "alpha": 0.12,
        "clips_children": true,
        "$container_size": [
            "100%c",
            "100%c"
        ],
        "animation_reset_name": "screen_animation_reset",
        "anims": [
            "@common.container_entrance_size_pop",
            "@common.container_entrance_size_push",
            "@common.container_exit_size_pop",
            "@common.container_exit_size_push"
        ],
        "anchor_from": "bottom_middle",
        "anchor_to": "bottom_middle",
        "offset": [
            0,
            -5
        ],
        "controls": [
            {
                "grid": {
                    "type": "grid",
                    "size": [
                        162,
                        18
                    ],
                    "grid_dimensions": [
                        9,
                        1
                    ],
                    "grid_item_template": "common.grid_item_for_hotbar",
                    "collection_name": "hotbar_items"
                }
            }
        ]
    },
    "dialog_background_hollow_common@dialog_background_common": {
        "layer": 2,
        "$fill_alpha|default": "$global_bloom_alpha",
        "alpha": 0.7,
        "$dialog_background_texture|default": "$bloom",
        "controls": [
            {
                "control": {
                    "type": "image",
                    "texture": "$dialog_background_texture",
                    "layer": -1,
                    "size": [
                        "100%+20px",
                        "100%+20px"
                    ],
                    "color": "$shadow",
                    "alpha": "$fill_alpha"
                }
            }
        ]
    },
    "dialog_background_opaque@dialog_background_common": {
        "texture": "$16x"
    },
    "dialog_background_hollow_1@dialog_background_hollow_common": {
        "texture": "$16x"
    },
    "dialog_background_hollow_2@dialog_background_hollow_common": {
        "texture": "$16x"
    },
    "dialog_background_hollow_3@dialog_background_hollow_common": {
        "texture": "$16x"
    },
    "dialog_background_hollow_4@dialog_background_hollow_common": {
        "texture": "$16x"
    },
    "dialog_background_hollow_4_thin@dialog_background_hollow_common": {
        "texture": "$16x"
    },
    "dialog_background_hollow_5@dialog_background_hollow_common": {
        "texture": "$16x"
    },
    "dialog_background_hollow_6@dialog_background_hollow_common": {
        "texture": "$16x"
    },
    "dialog_background_hollow_7@dialog_background_hollow_common": {
        "texture": "$16x"
    },
    "dialog_background_hollow_8@dialog_background_hollow_common": {
        "texture": "$16x"
    },
    "dialog_background_common": {
        "type": "image",
        "texture": "$16x",
        "alpha": 0.7,
        "color": "$surface",
        "layer": 1,
        "controls": [
            {
                "bloom": {
                    "type": "image",
                    "texture": "$bloom",
                    "alpha": "$global_bloom_alpha",
                    "color": "$shadow",
                    "size": [
                        "100%+20px",
                        "100%+20px"
                    ]
                }
            }
        ]
    },
    "highlight_slot": {
        "type": "image",
        "texture": "$16x",
        "color": "$primary",
        "size": [
            "100%",
            "100%"
        ],
        "alpha": 1
    },
    "highlight_slot_panel/white_border": {
        "ignored": true
    },
    "text_edit_box_place_holder_label": {
        "font_type": "$global_font_type"
    },
    "text_edit_box_label": {
        "font_type": "$global_font_type"
    },
    "text_magnifying_glass_image": {
        "type": "image",
        "texture": "textures/Quasar/container/spyglass",
        "color": "$onprimary",
        "layer": 10
    },
    "edit_box_indent": {
        "type": "image",
        "texture": "$edit_box_background",
        "color": "$surfacecontainerhighest",
        "$is_search_box|default": false,
        "$edit_box_background|default": "textures/Quasar/direction/down",
        "alpha": 0.7,
        "controls": [
            {
                "activation_indicator": {
                    "type": "image",
                    "texture": "$fk",
                    "size": [
                        "100%",
                        1
                    ],
                    "anchor_from": "bottom_middle",
                    "anchor_to": "bottom_middle",
                    "ignored": "$is_search_box",
                    "color": "$activation_indicator_color",
                    "$activation_indicator_color|default": "$outline"
                }
            }
        ]
    },
    "edit_box_indent_hover@common.edit_box_indent": {
        "texture": "$edit_box_background",
        "$edit_box_background|default": "textures/Quasar/direction/down",
        "color": "$surfacecontainerhighest",
        "$activation_indicator_color": "$primary"
    },
    "container_scroll_box_image": {
        "type": "image",
        "texture": "$fk",
        "color": "$primary",
        "alpha": "$a",
        "$a|default": 1
    },
    "container_scroll_bar_side_rails": {
        "type": "image",
        "layer": 1,
        "anchor_from": "top_left",
        "anchor_to": "top_left",
        "texture": "$fk",
        "color": "$secondary",
        "alpha": "$a",
        "$a|default": 1
    },
    "touch_scrollbar_box_image": {
        "type": "image",
        "texture": "$fk",
        "color": "$secondary",
        "layer": 3,
        "alpha": "@common.anim_scrollbar_box_fadeout"
    },
    "scroll_indent_image": {
        "type": "image",
        "texture": "$fk",
        "color": "$secondary",
        "size": [
            3,
            "100%"
        ],
        "layer": 3
    },
    "scroll_box_indent": {
        "type": "image",
        "texture": "$fk",
        "color": "$secondary",
        "layer": 1
    },
    "scrollbar_box_image": {
        "type": "image",
        "texture": "$fk",
        "color": "$primary",
        "size": [
            5,
            "100%"
        ],
        "layer": 4
    },
    "slot_selected": {
        "texture": "$16x",
        "size": [
            "100%",
            "100%"
        ],
        "alpha": "$slot_selected_alpha",
        "color": "$primary",
        "$slot_selected_alpha|default": 1
    },
    "cell_image_selected": {
        "type": "image",
        "texture": "textures/ui/recipe_book_touch_cell_selected",
        "layer": 1
    },
    "cell_image_selected_modified": {
        "type": "image",
        "texture": "$16x",
        "size": [
            "100%",
            "100%"
        ],
        "alpha": 1,
        "color": "$primary"
    },
    "cell_image_panel": {
        "type": "panel",
        "controls": [
            {
                "cell_image@common.cell_image": {
                    "$cell_selected_binding_name|default": "#is_selected_slot",
                    "visible": true,
                    "bindings": [
                        {
                            "binding_name": "(not $cell_selected_binding_name)",
                            "binding_name_override": "#visible",
                            "binding_type": "collection",
                            "binding_collection_name": "$item_collection_name"
                        }
                    ]
                }
            },
            {
                "cell_image_selected_modified@common.cell_image_selected_modified": {
                    "$cell_selected_binding_name|default": "#is_selected_slot",
                    "visible": false,
                    "bindings": [
                        {
                            "binding_name": "$cell_selected_binding_name",
                            "binding_name_override": "#visible",
                            "binding_type": "collection",
                            "binding_collection_name": "$item_collection_name"
                        }
                    ]
                }
            }
        ]
    },
    "screen_background": {
        "ignored": "($is_container)"
    },
    "bg_size_entrance_pop": {
        "anim_type": "size",
        "duration": 0.8,
        "easing": "out_cubic",
        "from": [
            0,
            0
        ],
        "to": [
            "10000%",
            "10000%"
        ],
        "play_event": "screen.entrance_pop"
    },
    "bg_size_entrance_push": {
        "anim_type": "size",
        "duration": 0.8,
        "easing": "out_cubic",
        "from": [
            0,
            0
        ],
        "to": [
            "10000%",
            "10000%"
        ],
        "play_event": "screen.entrance_push"
    },
    "bg_size_exit_pop": {
        "anim_type": "size",
        "duration": 0.8,
        "easing": "out_cubic",
        "to": [
            0,
            0
        ],
        "from": [
            "1000%",
            "1000%"
        ],
        "play_event": "screen.exit_pop"
    },
    "bg_size_exit_push": {
        "anim_type": "size",
        "duration": 0.8,
        "easing": "out_cubic",
        "to": [
            0,
            0
        ],
        "from": [
            "1000%",
            "1000%"
        ],
        "play_event": "screen.exit_push"
    },
    "top_bar@Quasar_Background.fk_primary_03_bloom": {
        "type": "image",
        "texture": "$fk",
        "alpha": 0.2,
        "color": "$background",
        "size": [
            "100%",
            23
        ]
    },
    "dropdown_background": {
        "layer": 1,
        "type": "image",
        "texture": "$16x",
        "color": "$background",
        "alpha": 0.7,
        "controls": [
            {
                "bloom": {
                    "type": "image",
                    "texture": "$bloom",
                    "alpha": "$global_bloom_alpha",
                    "color": "$shadow",
                    "layer": -1024,
                    "size": [
                        "100%+20px",
                        "100%+20px"
                    ]
                }
            }
        ]
    },
    "slider_button_state": {
        "type": "image",
        "layer": 4,
        "texture": "$4x",
        "color": "$primary"
    },
    "slider_button_layout@common.slider_button_state": {
        "texture": "$4x"
    },
    "slider_button_hover_layout@common.slider_button_state": {
        "texture": "$4x"
    },
    "slider_button_locked_layout@common.slider_button_state": {
        "texture": "$4x",
        "color": "$error"
    },
    "slider_button_indent_layout@common.slider_button_state": {
        "texture": "$4x"
    },
    "slider_box": {
        "type": "slider_box",
        "layer": 4,
        "size": [
            6,
            "200%"
        ],
        "anchor_to": "center",
        "anchor_from": "center",
        "default_control": "default",
        "hover_control": "hover",
        "locked_control": "locked",
        "indent_control": "indent",
        "controls": [
            {
                "default@$slider_box_layout": {
                    "layer": 2
                }
            },
            {
                "hover@$slider_box_hover_layout": {
                    "layer": 3,
                    "size": [
                        4,
                        "100%"
                    ]
                }
            },
            {
                "indent@$slider_box_indent_layout": {
                    "layer": 4
                }
            },
            {
                "locked@$slider_box_locked_layout": {
                    "layer": 1,
                    "controls": [
                        {
                            "transparent_grey": {
                                "type": "image",
                                "ignored": "$is_holographic",
                                "texture": "textures/Quasar/lock",
                                "color": "$error",
                                "size": [
                                    "100%",
                                    "100%y"
                                ],
                                "alpha": 1,
                                "layer": 5,
                                "bindings": [
                                    {
                                        "binding_type": "$slider_enabled_binding_type",
                                        "binding_condition": "$slider_enabled_binding_condition",
                                        "binding_collection_name": "$slider_collection_name",
                                        "binding_name": "(not $slider_enabled_binding_name)",
                                        "binding_name_override": "#visible"
                                    }
                                ]
                            }
                        }
                    ]
                }
            }
        ]
    },
    "slider_background": {
        "type": "image",
        "texture": "$8x",
        "color": "$surfacecontainerhighest"
    },
    "slider_background_hover": {
        "type": "image",
        "texture": "$8x",
        "color": "$surfacecontainerhighest"
    },
    "slider_progress": {
        "type": "image",
        "texture": "$8x",
        "color": "$primary"
    },
    "slider_progress_hover": {
        "type": "image",
        "texture": "$8x",
        "color": "$primary"
    },
    "slider_border": {
        "type": "image",
        "texture": "textures/Quasar/empty"
    },
    "slider_step": {
        "type": "image",
        "texture": "textures/Quasar/circle",
        "size": [
            "100%y",
            4
        ],
        "layer": 4,
        "color": "$surfacecontainerhighest",
        "offset": "$step_offset"
    },
    "slider_step_hover@common.slider_step": {
        "texture": "textures/Quasar/circle"
    },
    "slider_step_progress@common.slider_step": {
        "texture": "textures/Quasar/circle",
        "color": "$primary"
    },
    "slider_step_progress_hover@common.slider_step": {
        "texture": "textures/Quasar/circle",
        "color": "$primary"
    },
    "close_button_image": {
        "type": "image",
        "layer": 1,
        "texture": "$close_button_texture",
        "color": "$color",
        "$color|default": "$onprimarycontainer"
    },
    "close_button": {
        "type": "button",
        "size": [
            21,
            21
        ],
        "layer": 10,
        "anchor_from": "top_right",
        "anchor_to": "top_right",
        "$close_button_offset|default": [
            -2,
            2
        ],
        "offset": "$close_button_offset",
        "locked_control": "",
        "default_control": "default",
        "hover_control": "hover",
        "pressed_control": "pressed",
        "sound_name": "random.click",
        "sound_volume": 1,
        "sound_pitch": 1,
        "$close_button_panel_size|default": [
            15,
            15
        ],
        "$close_button_to_button_id|default": "button.menu_exit",
        "$default_button_alpha|default": 1,
        "$default_hover_alpha|default": 1,
        "$default_pressed_alpha|default": 1,
