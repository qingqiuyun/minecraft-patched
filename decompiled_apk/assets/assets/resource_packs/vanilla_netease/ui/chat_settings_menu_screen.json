{
    "namespace": "chat_seetings",
    "reset_button": {
        "$default_content_color": "$primary",
        "$hover_content_color": "$onsecondary",
        "$pressed_content_color": "$onsecondary",
        "$locked_content_color": "$error",
        "$default_button_texture": "$16x",
        "$hover_button_texture": "$16x",
        "$pressed_button_texture": "$16x",
        "$locked_button_texture": "$16x"
    },
    "chat_settings_popup@popup_dialog.form_fit_modal_dialog_popup": {
        "$modal_title": "chat.settings",
        "$popup_dialog_escape_button_name": "button.close_chat_settings",
        "$modal_contents": "chat_settings.chat_setting_scrolling_panel",
        "$screen_background_alpha": 0.4,
        "$dialog_background_texture": "$bloom",
        "$fill_alpha": 1,
        "$modal_contents_padding": [
            8,
            6
        ]
    }
}