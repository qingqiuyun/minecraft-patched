{
  "namespace": "chat",
  "small_button": {
    "$default_content_color": "$primary",
    "$hover_content_color": "$onsecondary",
    "$pressed_content_color": "$onsecondary",
    "$locked_content_color": "$error",
    "$default_button_texture": "$16x",
    "$hover_button_texture": "$16x",
    "$pressed_button_texture": "$16x",
    "$locked_button_texture": "$16x"
  },
  "send_button": {
    "$default_content_color": "$primary",
    "$hover_content_color": "$onsecondary",
    "$pressed_content_color": "$onsecondary",
    "$locked_content_color": "$error",
    "$default_button_texture": "$16x",
    "$hover_button_texture": "$16x",
    "$pressed_button_texture": "$16x",
    "$locked_button_texture": "$16x"
  },
  "messages_text": {
    "type": "panel",
    "size": [
      "100%",
      "100%c"
    ],
    "controls": [
      {
        "text": {
          "type": "label",
          "color": "$onprimarycontainer",
          "localize": false,
          "size": [
            "default",
            "default"
          ],
          "max_size": [
            "100%",
            "default"
          ],
          "anims": [
            "@chat.text_offset_anim"
          ],
          "text_alignment": "left",
          "anchor_from": "left_middle",
          "anchor_to": "left_middle",
          "text": "#text",
          "text_tts": "#text_tts",
          "font_type": "$global_font_type",
          "font_scale_factor": "$chat_font_scale_factor",
          "line_padding": "$chat_line_spacing",
          "controls": [
            {
              "image": {
                "type": "image",
                "texture": "$4x",
                "alpha": 0.3,
                "color": "$background",
                "controls": [
                  {
                    "bloom": {
                      "type": "image",
                      "texture": "$bloom",
                      "alpha": "$global_bloom_alpha",
                      "color": "$shadow",
                      "layer": -1024,
                      "size": [
                        "100%+20px",
                        "100%+20px"
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ],
    "bindings": [
      {
        "binding_name": "#chat_visible",
        "binding_name_override": "#visible"
      }
    ]
  },
  "messages_scrolling_panel": {
    "$messages_scrolling_panel": false,
    "$jump_to_bottom_on_update": false
  },
  "text_offset_anim": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "from": [
      "-20%",
      0
    ],
    "to": [
      5,
      0
    ]
  },
  "chat_header@common_store.store_top_bar": {
    "texture": "$16x",
    "color": "$background",
    "alpha": 0.3,
    "anchor_to": "top_left",
    "anchor_from": "top_left",
    "$back_button_text": "controller.buttonTip.back",
    "animation_reset_name": "screen_animation_reset",
    "anims": [
      "@chat.chat_top_panel_entrance_pop",
      "@chat.chat_top_panel_exit_pop",
      "@chat.chat_top_panel_entrance_push",
      "@chat.chat_top_panel_exit_push"
    ],
    "controls": [
      {
        "title_panel": {
          "type": "panel",
          "size": [
            "100%",
            20
          ],
          "controls": [
            {
              "back_button_content_panel@chat.back_content_panel": {
                "offset": [
                  2,
                  0
                ]
              }
            },
            {
              "title@chat.title_text": {
                "bindings": [
                  {
                    "binding_name": "#chat_title_visible",
                    "binding_name_override": "#visible"
                  }
                ]
              }
            },
            {
              "popup_dialog_factory": {
                "type": "factory",
                "control_ids": {
                  "toast_message": "@chat.popup_toast"
                }
              }
            },
            {
              "chat_header_content_area": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": [
                  "100%c",
                  60
                ],
                "offset": [
                  0,
                  1
                ],
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",
                "bindings": [
                  {
                    "binding_name": "#chat_coordinate_dropdown_visible",
                    "binding_name_override": "#visible",
                    "binding_type": "global"
                  }
                ],
                "controls": [
                  {
                    "coordinate_dropdown@chat.coordinate_dropdown": {
                      "size": [
                        100,
                        20
                      ]
                    }
                  },
                  {
                    "coordinates_panel": {
                      "type": "panel",
                      "size": [
                        "100%c",
                        16
                      ],
                      "controls": [
                        {
                          "coordinates_background_image": {
                            "type": "image",
                            "anchor_to": "center",
                            "anchor_from": "center",
                            "size": [
                              "100%c + 14px",
                              "100%"
                            ],
                            "min_size": [
                              160,
                              "100%"
                            ],
                            "texture": "$16x",
                            "color": "$background",
                            "alpha": 0.3,
                            "layer": 1,
                            "controls": [
                              {
                                "coordinates_text": {
                                  "type": "label",
                                  "size": [
                                    "default",
                                    10
                                  ],
                                  "text": "#text",
                                  "font_type": "$global_font_type",
                                  "color": "$onprimarycontainer",
                                  "layer": 2,
                                  "bindings": [
                                    {
                                      "binding_name": "#coordinates_text",
                                      "binding_name_override": "#text"
                                    }
                                  ]
                                }
                              }
                            ]
                          }
                        }
                      ]
                    }
                  },
                  {
                    "copy_coordinate_button@chat.copy_coordinate_button": {
                      "size": [
                        64,
                        16
                      ]
                    }
                  },
                  {
                    "icon@common.gamepad_helper_y": {
                      "$gamepad_helper_size": [
                        16,
                        16
                      ],
                      "$gamepad_helper_icon_size": [
                        16,
                        16
                      ],
                      "$gamepad_helper_icon_image_size": [
                        26,
                        26
                      ],
                      "$icon_description_bind_type": "none",
                      "$gamepad_helper_visible_binding_name": "#is_using_gamepad"
                    }
                  },
                  {
                    "paste_button@chat.paste_button": {
                      "size": [
                        64,
                        16
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "bloom": {
          "type": "image",
          "texture": "$bloom",
          "alpha": "$global_bloom_alpha",
          "color": "$shadow",
          "layer": -1024,
          "size": [
            "100%+20px",
            "100%+20px"
          ]
        }
      }
    ]
  },
  "copy_image": {
    "type": "image",
    "size": [
      12,
      12
    ],
    "texture": "textures/Quasar/container/cartography/copy",
    "color": "$onprimarycontainer"
  },
  "paste_image": {
    "type": "image",
    "size": [
      12,
      12
    ],
    "texture": "textures/Quasar/container/cartography/paste",
    "color": "$onprimarycontainer"
  },
  "text_offset_anim_push": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "to": [
      -500,
      0
    ],
    "from": [
      0,
      0
    ],
    "end_event": "screen.exit_end",
    "play_event": "screen.exit_pop"
  },
  "chat_screen_content/messages_panel": {
    "anims": [
      "@chat.text_offset_anim_push"
    ]
  },
  "toggle@Quasar_toggle.toggle": {
    "size": [
      "100%y",
      "100%"
    ],
    "$button_icon": "textures/Quasar/chat/newline",
    "$toggle_name": "toggle",
    "$toggle_view_binding_name": "chat.toggle",
    "$toggle_check_anim": "@pause.toggle_check",
    "$toggle_uncheck_anim": "@pause.toggle_uncheck",
    "$custom_controls": "pause.icon_controls",
    "$unchecked_controls": "Quasar_toggle.normal_toggle_uncheck",
    "$checked_controls": "Quasar_toggle.normal_toggle_check"
  },
  "text_edit_box@common.text_edit_box": {
    "max_length": 32767,
    "always_listening": false,
    "$text_edit_box_label_size": [
      "default",
      "default"
    ],
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "chat.toggle",
        "source_property_name": "(not #toggle_state)",
        "target_property_name": "#visible"
      }
    ]
  },
  "text_edit_box_newline@chat.text_edit_box": {
    "enabled_newline": true,
    "bindings": [
      {
        "binding_type": "view",
        "source_control_name": "chat.toggle",
        "source_property_name": "#toggle_state",
        "target_property_name": "#visible"
      }
    ]
  },
  "chat_autocomplete@small_button": {
    "$button_content": "chat.tab_down",
    "$pressed_button_name": "button.chat_autocomplete",
    "anchor_from": "bottom_left",
    "anchor_to": "bottom_left",
    "ignored": "(not$touch)"
  },
  "chat_autocomplete_back@small_button": {
    "$button_content": "chat.tab_up",
    "$pressed_button_name": "button.chat_autocomplete_back",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "ignored": "(not$touch)"
  },
  "chat_next@small_button": {
    "$button_content": "chat.down",
    "$pressed_button_name": "button.chat_next_message",
    "anchor_from": "bottom_right",
    "anchor_to": "bottom_right",
    "ignored": "(not$touch)"
  },
  "chat_previous@small_button": {
    "$button_content": "chat.up",
    "$pressed_button_name": "button.chat_previous_message",
    "anchor_from": "top_right",
    "anchor_to": "top_right",
    "ignored": "(not$touch)"
  },
  "button_icon": {
    "type": "image",
    "color": "$onprimarycontainer"
  },
  "tab_up@chat.button_icon": {
    "texture": "textures/Quasar/chat/tab_up"
  },
  "tab_down@chat.button_icon": {
    "texture": "textures/Quasar/chat/tab_down"
  },
  "up@chat.button_icon": {
    "texture": "textures/Quasar/chat/up"
  },
  "down@chat.button_icon": {
    "texture": "textures/Quasar/chat/down"
  },
  "button_panel": {
    "type": "image",
    "texture": "$16x",
    "color": "$background",
    "alpha": 0.7,
    "size": [
      64,
      64
    ],
    "$offset": [
      -25,
      -30
    ],
    "animation_reset_name": "screen_animation_reset",
    "anims": [
      "@chat.button_panel_entrance_pop",
      "@chat.button_panel_entrance_push",
      "@chat.button_panel_exit_pop",
      "@chat.button_panel_exit_push"
    ],
    "ignored": "(not$touch)",
    "controls": [
      {
        "tab_up@chat.chat_autocomplete_back": {
          "offset": [
            3,
            3
          ]
        }
      },
      {
        "tab_down@chat.chat_autocomplete": {
          "offset": [
            3,
            -3
          ]
        }
      },
      {
        "up@chat.chat_previous": {
          "offset": [
            -3,
            3
          ]
        }
      },
      {
        "down@chat.chat_next": {
          "offset": [
            -3,
            -3
          ]
        }
      },
      {
        "bloom": {
          "type": "image",
          "texture": "$bloom",
          "alpha": "$global_bloom_alpha",
          "color": "$shadow",
          "layer": -1024,
          "size": [
            "100%+20px",
            "100%+20px"
          ]
        }
      }
    ]
  },
  "chat_screen@common.base_screen": {
    "close_on_player_hurt": false,
    "$screen_bg_content": "common.empty_panel",
    "$screen_animations": [
      "@common.screen_exit_animation_push_fade",
      "@common.screen_exit_animation_pop_fade",
      "@common.screen_entrance_animation_push_fade",
      "@common.screen_entrance_animation_pop_fade"
    ]
  },
  "chat_screen_content": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": [
          {
            "button_panel@chat.button_panel": {
              "anchor_from": "bottom_right",
              "anchor_to": "bottom_right"
            }
          }//,
          // {
          //   "info@Quasar/Panel/Surface.creator_information": {}
          // }
        ]
      }
    ]
  },
  "chat_bottom_panel": {
    "animation_reset_name": "screen_animation_reset",
    "anims": [
      "@chat.chat_bottom_panel_entrance_pop",
      "@chat.chat_bottom_panel_exit_pop",
      "@chat.chat_bottom_panel_entrance_push",
      "@chat.chat_bottom_panel_exit_push"
    ],
    "controls": [
      { "keyboard_button@chat.keyboard_button": {} },
      {
        "host_main_button@host_options.host_main_button": {
          "ignored": "$is_pregame",
          "$focus_override_up": "coordinate_dropdown_focus_id"
        }
      },
      { "chat_settings@chat.chat_settings_button": {} },
      { "text_box@chat.text_edit_box": {} },
      { "text_box_newline@chat.text_edit_box_newline": {} },
      { "toggle@chat.toggle": {} },
      { "send_button@chat.send_button": { "offset": [ -20, 0 ] } }
    ]
  },
  "chat_bottom_panel_entrance_pop": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "from": [ 0, 200 ],
    "to": [ 0, 0 ],
    "play_event": "screen.entrance_pop",
    "end_event": "screen.entrance_end"
  },
  "chat_bottom_panel_exit_pop": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "to": [ 0, 200 ],
    "from": [ 0, 0 ],
    "play_event": "screen.exit_pop",
    "end_event": "screen.exit_end"
  },
  "chat_top_panel_entrance_pop": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "from": [ 0, -200 ],
    "to": [ 0, 0 ],
    "play_event": "screen.entrance_pop",
    "end_event": "screen.entrance_end"
  },
  "chat_top_panel_exit_pop": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "to": [ 0, -200 ],
    "from": [ 0, 0 ],
    "play_event": "screen.exit_pop",
    "end_event": "screen.exit_end"
  },
  "chat_bottom_panel_entrance_push": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "from": [ 0, 200 ],
    "to": [ 0, 0 ],
    "play_event": "screen.entrance_push",
    "end_event": "screen.entrance_end"
  },
  "chat_bottom_panel_exit_push": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "to": [ 0, 200 ],
    "from": [ 0, 0 ],
    "play_event": "screen.exit_push",
    "end_event": "screen.exit_end"
  },
  "chat_top_panel_entrance_push": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "from": [ 0, -200 ],
    "to": [ 0, 0 ],
    "play_event": "screen.entrance_push",
    "end_event": "screen.entrance_end"
  },
  "chat_top_panel_exit_push": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "to": [ 0, -200 ],
    "from": [ 0, 0 ],
    "play_event": "screen.exit_push",
    "end_event": "screen.exit_end"
  },
  "button_panel_entrance_pop": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "from": [ 200, 0 ],
    "to": "$offset",
    "play_event": "screen.entrance_pop",
    "end_event": "screen.entrance_end"
  },
  "button_panel_exit_pop": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "to": [ 200, 0 ],
    "from": "$offset",
    "play_event": "screen.exit_pop",
    "end_event": "screen.exit_end"
  },
  "button_panel_entrance_push": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "from": [ 200, 0 ],
    "to": "$offset",
    "play_event": "screen.entrance_push",
    "end_event": "screen.entrance_end"
  },
  "button_panel_exit_push": {
    "anim_type": "offset",
    "duration": 0.4,
    "easing": "out_cubic",
    "to": [ 200, 0 ],
    "from": "$offset",
    "play_event": "screen.exit_push",
    "end_event": "screen.exit_end"
  },
  

  "chat_new_content": {//待定
    "type": "panel",
    "size": ["100%","100%"],
    "controls": [
      {
        
      }
    ]
  }
}