            "#item_id_aux": 17301504
          }
        }
      },
      {
        "item_seperator_2@beacon.item_seperator_label": {
          "offset": [ 60, 0 ]
        }
      },
      {
        "gold@beacon.item_renderer": {
          "offset": [ 66, 0 ],
