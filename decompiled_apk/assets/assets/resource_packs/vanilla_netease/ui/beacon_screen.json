{
    "namespace": "beacon",
    "hover_text@common.hover_text_modified": {
    "bindings": [
      {
        "binding_name": "#button_hover",
        "binding_name_override": "#hover_text",
        "binding_collection_name": "$button_name",
        "binding_type": "collection"
      }
    ]
  },
    "pyramid_panel": {
    "type": "panel",
    "size": [ "100%", "100%" ],
    "anchor_to": "top_middle",
    "anchor_from": "top_middle",
    "controls": [
      {
        "level1@beacon.pyramid_image": {
          "texture": "textures/Quasar/container/pyramid/1",
          "offset": [ -98, 18 ],
        "color": "$primary"
        }
      },
      {
        "level2@beacon.pyramid_image": {
          "texture": "textures/Quasar/container/pyramid/2",
          "offset": [ -98, 43 ],
        "color": "$primary"
        }
      },
      {
        "level3@beacon.pyramid_image": {
          "texture": "textures/Quasar/container/pyramid/3",
          "offset": [ -98, 68 ],
        "color": "$primary"
        }
      },
      {
        "level4@beacon.pyramid_image": {
          "texture": "textures/Quasar/container/pyramid/4",
          "offset": [ 42, 18 ],
        "color": "$primary"
        }
      }
    ]
  },
  "pyramid_image": {
    "size": [ 20, 20 ],
        "color": "$primary"
  },
  "beacon_panel": {
    "type": "panel",
    "controls": [
      { "container_gamepad_helpers@common.container_gamepad_helpers": {} },
      {
        "selected_item_details_factory@common.selected_item_details_factory": {
          "control_name": "@beacon.selected_item_details"
        }
      },
      { "item_lock_notification_factory@common.item_lock_notification_factory": {} },
      {
        "root_panel@common.root_panel": {
          "layer": 1,
          "size": [ 256, 219 ],
          "controls": [
            { "common_panel@common.common_panel": {
              "$container_size": [ 256, 219 ],
                "animation_reset_name": "screen_animation_reset",
                "anims": [
                  "@common.container_entrance_size_pop",
                  "@common.container_entrance_size_push",
                  "@common.container_exit_size_pop",
                  "@common.container_exit_size_push"
                ]
            } },
            {
              "beacon_inventory": {
                "type": "panel",
                "$container_size": [ 256, 219 ],
                "animation_reset_name": "screen_animation_reset",
                "anims": [
                  "@common.container_entrance_size_pop",
                  "@common.container_entrance_size_push",
                  "@common.container_exit_size_pop",
                  "@common.container_exit_size_push"
                ],
                "clips_children": true,
                "controls": [
                  {
                    "beacon_inner_panel@beacon.beacon_inner_panel": {
                      "offset": [ 0, 4 ],
                      "layer": 2
                    }
                  },
                  {
                    "payment_panel@beacon.payment_panel": {
                      "offset": [ 0, 8 ],
                      "layer": 2
                    }
                  },
                  {
                    "inventory_panel_bottom_half@common.inventory_panel_bottom_half": {
                      "layer": 2,
                      "$button_ref": "beacon.inventory_slot_button"
                    }
                  },
                  {
                    "hotbar_grid_template@common.hotbar_grid_template_modified": {
                      "$button_ref": "beacon.hotbar_slot_button",
                      "layer": 15
                    }
                  },
                  { "inventory_selected_icon_button@common.inventory_selected_icon_button": {} },
                  { "gamepad_cursor@common.gamepad_cursor_button": {} }
                ]
              }
            }
          ]
        }
      },
      { "flying_item_renderer@common.flying_item_renderer": { "layer": 12 } }
    ]
  },
  "beacon_inner_panel": {
    "type": "image",
    "texture": "$16x",
    "color": "$primary",
    "alpha": 0.12,
    "$container_size": [ 212, 97 ],
    "clips_children": true,
    "animation_reset_name": "screen_animation_reset",
    "anims": [
      "@common.container_entrance_size_pop",
      "@common.container_entrance_size_push",
      "@common.container_exit_size_pop",
      "@common.container_exit_size_push"
    ],
    "anchor_from": "top_middle",
    "anchor_to": "top_middle",
    "controls": [
      { "button_panel@beacon.button_panel": {} },
      { "pyramid_panel@beacon.pyramid_panel": { "layer": 1 } },
      {
        "middle_strip@beacon.image_atlas": {
          "offset": [ 0, 3 ],
          "layer": 1,
          "anchor_from": "top_middle",
          "anchor_to": "top_middle",
          "texture": "textures/ui/middle_strip",
          "size": [ 2, "100%-6px" ]
        }
      },
      {
        "primary_power_label@beacon.beacon_label": {
          "text": "tile.beacon.primary",
          "offset": [ -54, 6 ]
        }
      },
      {
        "secondary_power_label@beacon.beacon_label": {
          "text": "tile.beacon.secondary",
          "offset": [ 52, 6 ]
        }
      }
    ]
  },
  "payment_panel": {
    "type": "image",
    "texture": "$16x",
    "color": "$primary",
    "alpha": 0.12,
    "$container_size": [ 190, 22 ],
    "animation_reset_name": "screen_animation_reset",
    "anims": [
      "@common.container_entrance_size_pop",
      "@common.container_entrance_size_push",
      "@common.container_exit_size_pop",
      "@common.container_exit_size_push"
    ],
    "clips_children": true,
    "controls": [
      {
        "confirm_panel@beacon.panel_template": {
          "offset": [ 48, 0 ],
          "$button_name": "confirm",
          "$image_texture": "textures/Quasar/tick",
          "$color": "green",
          "$image_size": [ 14, 12 ],
          "$button_control": "beacon.button_template",
          "anchor_from": "center",
          "anchor_to": "left_middle"
        }
      },
      {
        "cancel_panel@beacon.panel_template": {
          "offset": [ 74, 0 ],
          "$button_name": "cancel",
          "$image_texture": "textures/Quasar/cross",
          "$color": "$error",
          "$image_size": [ 13, 13 ],
          "$button_control": "beacon.button_template",
          "anchor_from": "center",
          "anchor_to": "left_middle"
        }
      },
      {
        "ingredient_item@common.container_item": {
          "$item_collection_name": "beacon_payment_items",
          "offset": [ 19, 0 ],
          "anchor_from": "center",
          "anchor_to": "left_middle"/*,
          "controls": [
            {
                "bg@Quasar_Background.16x_primary_03": {
                    "color": "$secondary"
                }
            }
          ]*/
        }
      },
      {
        "usable_items_panel@beacon.usable_items_panel": {
          "offset": [ 10, 0 ],
          "anchor_from": "center",
          "anchor_to": "right_middle"
        }
      }
    ]
  },
  "item_seperator_label": {
    "type": "label",
    "text": "|",
    "font_type": "OldSmoothFont",
    "size": [ 18, 18 ],
    "font_scale_factor": 1.5,
    "anchor_to": "top_left",
    "anchor_from": "top_left"
  },
