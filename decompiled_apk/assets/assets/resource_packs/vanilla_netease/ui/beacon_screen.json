            "#item_id_aux": 17432576
          }
        }
      },
      {
        "item_seperator_3@beacon.item_seperator_label": {
          "offset": [ 82, 0 ]
        }
      },
      {
        "iron@beacon.item_renderer": {
          "offset": [ 88, 0 ],
          "property_bag": {
            "#item_id_aux": 17367040
          }
        }
      }
    ]
  },
  "toggle_image": {
    "type": "image",
    "texture": "$16x",
    "alpha": 0.4,
    "color": "$secondary",
    "$locked|default": false,
    "controls": [
        {
            "lock": {
                "type": "image",
                "texture": "textures/Quasar/lock",
                "color": "$error",
                "size": [ "60%", "60%" ],
                "ignored": "(not $locked)",
                "layer": 32767
            }
        }
    ]
  },
  "button_unchecked_default@beacon.toggle_image": {
    "texture": "$16x"
  },
  "button_unchecked_hover@beacon.toggle_image": {
    "size": [ 22, 22 ],
    "texture": "$16x",
    "alpha": 0.6,
    "color": "$tertiary",
    "controls": [
      { "hover_text@beacon.hover_text": {} }
    ]
  },
  "button_checked_hover@beacon.toggle_image": {
    "texture": "$16x",
    "color": "white",
    "alpha": 0.8,
    "controls": [
      { "hover_text@beacon.hover_text": {} }
    ]
  },
  "button_locked@beacon.toggle_image": {
    "texture": "$16x",
    "$locked": true
  },
  "button_locked_hover@beacon.toggle_image": {
    "texture": "$16x",
    "$locked": true,
    "alpha": 0.6,
    "color": "$tertiary",
    "controls": [
      { "hover_text@beacon.hover_text": {} }
    ]
  },
  "button_checked@beacon.toggle_image": {
    "texture": "$16x",
    "color": "white",
    "alpha": 0.8
  },
  "base_button@common.button": {
    "size": [ 20, 20 ],
    "layer": 0,
    "focus_wrap_enabled": false,
    "bindings": [
      {
        "binding_name": "$button_active",
        "binding_name_override": "#visible",
        "binding_collection_name": "$button_name",
        "binding_type": "collection"
      },
      {
        "binding_collection_name": "$button_name",
        "binding_type": "collection_details"
      }
    ],
    "controls": [
      {
        "default": {
          "type": "image",
          "texture": "$16x",
          "color": "$secondary",
          "alpha": 0.6
        }
      },
      {
        "hover": {
          "type": "image",
          "texture": "$16x",
          "color": "$tertiary",
          "alpha": 0.6
        }
      },
      {
        "pressed": {
          "type": "image",
          "texture": "$16x",
          "alpha": 0.8
        }
      }
    ]
  },
  "inactive_button@beacon.base_button": {
    "$button_active": "#inactive",
    "pressed_control": "",
    "button_mappings": [],
    "controls": [
      {
        "default": {
          "type": "image",
          "texture": "$16x",
          "color": "$secondary",
          "alpha": 0.6,
          "controls": [
            {
                "lock": {
                    "type": "image",
                    "texture": "textures/Quasar/lock",
                    "color": "$error",
                    "size": [ "60%", "60%" ],
                    "layer": 32767
                }
            }
          ]
        }
      },
      {
        "hover": {
          "type": "image",
          "texture": "$16x",
          "color": "$tertiary",
          "alpha": 0.8,
          "controls": [
            {
                "lock": {
                    "type": "image",
                    "texture": "textures/Quasar/lock",
                    "color": "$error",
                    "size": [ "60%", "60%" ],
                    "layer": 32767
                }
            }
          ]
        }
      }
    ]
  },
  "base_image@beacon.image_atlas": {
    "$image_size|default": [ 18, 18 ],
    "size": "$image_size",
    "texture": "$image_texture",
    "color": "$color",
    "$color|default": "",
    "bindings": [
      {
        "binding_name": "#button_visible",
        "binding_name_override": "#visible",
        "binding_collection_name": "$button_name",
        "binding_type": "collection"
      }
    ]
  }
}