{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "minecraft:ender_crystal",
      "materials": {
      "entity_esp_blend": "entity_esp_blend",
      "entity_esp": "entity_esp",
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/entity/endercrystal/endercrystal",
        "chams": "galaxite/entity/chams",
        "range": "galaxite/entity/range",
        "notification": "galaxite/entity/noti",
        "beam": "textures/entity/endercrystal/endercrystal_beam"
      },
      "geometry": {
        "notification": "geometry.galaxite.crystal.noti",
        "range": "geometry.galaxite.endcrystal.hitbox",
        "default": "geometry.galaxite.endercrystal"
      },
      "animations": {
        "noti": "animation.galaxite.crystal.noti",
        "range": "animation.galaxite.endcrystal.hitbox",
        "move": "animation.ender_crystal.move"
      },
      "scripts": {
        "initialize": [
          "variable.time_offset = Math.random(0, 100000);"
        ],
        "animate": [
        "range",
        "noti",
          "move"
        ]
      },
      "render_controllers": [ "controller.render.ender_crystal", "controller.render.end_crystal_chams", "controller.render.end_crystal_hitbox", "controller.render.end_crystal_notification" ]
    }
  }
}