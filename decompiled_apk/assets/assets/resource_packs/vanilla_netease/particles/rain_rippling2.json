{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "rct:rain_rippling2",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "textures/rct/particle/rain_rippling"
      }
    },
    "components": {
      "minecraft:emitter_rate_manual": {
        "max_particles": 300
      },
      "minecraft:emitter_initialization": {
        "creation_expression": "variable.size_uv = Math.random(0.13, 0.16);"
      },
      "minecraft:emitter_lifetime_expression": {
        "activation_expression": 1,
        "expiration_expression": 0
      },
      "minecraft:emitter_shape_point": {
        "offset": [0,0,0]
      },
      "minecraft:particle_initial_speed": 0.0,
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "Math.Random(0.4, 0.6)"
      },
      "minecraft:particle_motion_dynamic": {},
      "minecraft:particle_appearance_billboard": {
        "size": [
          "variable.particle_age / variable.particle_lifetime * variable.size_uv",
          "variable.particle_age / variable.particle_lifetime * variable.size_uv"
        ],
        "facing_camera_mode": "emitter_transform_xz",
        "uv": {
          "texture_width": 6,
          "texture_height": 1,
          "flipbook": {
            "base_UV": [ 0, 0 ],
            "size_UV": [ 1, 1 ],
            "step_UV": [ 1, 0 ],
            "frames_per_second": 1,
            "max_frame": 6,
            "stretch_to_lifetime": true,
            "loop": false
          }
        }
      },
      "minecraft:particle_appearance_lighting": {}
    }
  }
}
