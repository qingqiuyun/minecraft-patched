{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "rct:rain_spray",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "textures/rct/particle/rain_spray"
      }
    },
    "components": {
      "minecraft:emitter_rate_manual": {
        "max_particles": 300
      },
      "minecraft:particle_initial_spin": {
        "rotation": 0,
        "rotation_rate": "variable.rotation"
      },
      "minecraft:emitter_initialization": {
        "creation_expression": "variable.step_uv_x = math.ceil(Math.random(0, 3)) - 1; variable.step_uv_y = math.ceil(Math.random(0, 3)) - 1; variable.size_uv = Math.random(1.8, 2.0); variable.rotation = Math.random(60, 80);"
      },
      "minecraft:emitter_rate_instant": {
        "num_particles": 1
      },
      "minecraft:emitter_lifetime_expression": {
        "activation_expression": 1,
        "expiration_expression": 0
      },
      "minecraft:emitter_shape_point": {
        "offset": [
          0,
          0.2,
          0
        ],
        "direction": [
          1,
          0,
          1
        ]
      },
      "minecraft:particle_initial_speed": "Math.random(0.6, 0.8)",
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "Math.random(2, 3)"
      },
      "minecraft:particle_motion_collision": {
        "coefficient_of_restitution": 0.1,
        "collision_drag": 10.0,
        "collision_radius": 0.01
      },
      "minecraft:particle_motion_dynamic": {},
      "minecraft:particle_appearance_billboard": {
        "size": [
          "variable.particle_age / variable.particle_lifetime < 0.25 ? (variable.particle_age / variable.particle_lifetime * 4 * variable.size_uv) : variable.size_uv - (variable.particle_age / variable.particle_lifetime * variable.size_uv / 3)",
          "variable.particle_age / variable.particle_lifetime < 0.25 ? (variable.particle_age / variable.particle_lifetime * 4 * variable.size_uv) : variable.size_uv - (variable.particle_age / variable.particle_lifetime * variable.size_uv / 3)"
        ],
        "facing_camera_mode": "rotate_xyz",
        "uv": {
          "texture_width": 3,
          "texture_height": 4,
          "uv": [
            "variable.step_uv_x",
            "variable.step_uv_y"
          ],
          "uv_size": [
            1,
            1
          ]
        }
      },
      "minecraft:particle_appearance_lighting": {}
    }
  }
}