{
  "format_version": "1.10.0",
  "particle_effect": {
    "description": {
      "identifier": "rct:rain_splash_particle2",
      "basic_render_parameters": {
        "material": "particles_blend",
        "texture": "textures/rct/particle/particles"
      }
    },
    "events": {
      "rippling": {
        "particle_effect": {
          "effect": "rct:rain_rippling2",
          "type": "particle_with_velocity"
        }
      }
    },
    "components": {
      "minecraft:emitter_rate_manual": {
        "max_particles": 300
      },
      "minecraft:emitter_lifetime_expression": {
        "activation_expression": 1,
        "expiration_expression": 0
      },
      "minecraft:emitter_shape_point": {
      },
      "minecraft:particle_initial_speed": -6.0,
      "minecraft:particle_lifetime_expression": {
        "max_lifetime": "Math.Random(0.19, 0.21)"
      },
      "minecraft:particle_motion_dynamic": {
        "linear_acceleration": [ 0.0, "30.0 + variable.particle_random_2*60.0 - variable.particle_age*480.0", 0.0 ],
        "linear_drag_coefficient": 20.0
      },
      "minecraft:particle_motion_collision": {
        "coefficient_of_restitution": 0.1,
        "collision_drag": 10.0,
        "collision_radius": 0.01
      },
      "minecraft:particle_appearance_billboard": {
        "size": [ 0.175, 0.175 ],
        "facing_camera_mode": "lookat_xyz",
        "uv": {
          "texture_width": 128,
          "texture_height": 128,
          "uv": [ "24+Math.Round(variable.particle_random_1*3.0)*8", 8 ],
          "uv_size": [ 8, 8 ]
        }
      },
      "minecraft:particle_appearance_lighting": {},
      "minecraft:particle_lifetime_events": {
        "timeline": {
          "0.0": "rippling"
        }
      }
    }
  }
}
